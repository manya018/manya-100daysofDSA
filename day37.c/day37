#include <stdio.h>
#define MAX 50

int pq[MAX];
int n = 0;   

void insert(int value) {
    if (n == MAX) {
        printf("Queue Overflow\n");
        return;
    }

    int i = n - 1;

    while (i >= 0 && pq[i] > value) {
        pq[i + 1] = pq[i];
        i--;
    }

    pq[i + 1] = value;
    n++;

    printf("%d inserted\n", value);
}

void delete() {
    if (n == 0) {
        printf("Queue Underflow\n");
        return;
    }

    printf("%d deleted\n", pq[0]);

    for (int i = 0; i < n - 1; i++) {
        pq[i] = pq[i + 1];
    }

    n--;
}

void display() {
    if (n == 0) {
        printf("Queue is empty\n");
        return;
    }

    printf("Priority Queue: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", pq[i]);
    }
    printf("\n");
}

int main() {
    insert(30);
    insert(10);
    insert(20);
    insert(5);

    display();

    delete();
    display();

    return 0;
}
